# Google Sign-In — create an OAuth Client ID in Google Cloud Console.
# Add the exact app origin to Authorized JavaScript origins for local dev.
# Usually one or both of these:
#   http://localhost:5175
#   http://127.0.0.1:5175
GOOGLE_CLIENT_ID=

# Production / Vercel: Neon Postgres connection string from Vercel Marketplace.
DATABASE_URL=

# Optional local SQLite DB path. Defaults to ./.data/budget.sqlite
BUDGET_DB_PATH=
