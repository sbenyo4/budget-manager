# open-finance.ai credentials — copy to .env and fill in real values.
# Get clientId + clientSecret from https://dashboard.open-finance.ai
# (initial access: contact Support@open-finance.ai).
# While these are empty the app runs in demo mode with sample data.
# These are read server-side only (vite.config.ts) and never reach the browser.
OPEN_FINANCE_CLIENT_ID=
OPEN_FINANCE_CLIENT_SECRET=
OPEN_FINANCE_USER_ID=
# Optional — the {prefix} in https://{prefix}.open-finance.ai/v2 (default: api)
OPEN_FINANCE_API_PREFIX=api

# Google Sign-In — create an OAuth Client ID in Google Cloud Console.
# Add the exact app origin to Authorized JavaScript origins for local dev.
# Usually one or both of these:
#   http://localhost:5175
#   http://127.0.0.1:5175
GOOGLE_CLIENT_ID=

# Optional server-side DB path. Defaults to ./.data/budget.sqlite
BUDGET_DB_PATH=
